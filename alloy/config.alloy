// ─────────────────────────────────────────────────────────────
// Grafana Alloy — ship logs from a Debian 13 host to Loki
//
// TEMPLATE: monitoring.sh reads this file and replaces @@LOKI_ENDPOINT@@
//   with the Loki base URL (LOKI_URL) before installing it to
//   /etc/alloy/config.alloy. To deploy by hand, swap @@LOKI_ENDPOINT@@
//   for your Loki base URL (e.g. http://localhost:3100).
//
//   Docker container logs are captured via the JOURNAL, not the Docker socket:
//   point Docker's log-driver at journald and the lines flow in like any other
//   journal entry. The relabel rules that promote container/image fields to
//   labels are delimited by @@ALLOY_DOCKER_BEGIN@@ / @@ALLOY_DOCKER_END@@;
//   monitoring.sh strips them unless Docker log capture is enabled. (This works
//   for both rootful and rootless Docker — no socket access needed.)
//
// Strategy: JOURNAL-FIRST.
//   On a systemd host the journal already holds kernel, every
//   service unit, sshd/sudo/PAM auth, and cron — with accurate
//   timestamps and a real severity level. We treat it as the
//   primary source and only scrape FILES that do NOT flow into
//   the journal (apt/dpkg/unattended-upgrades/auditd).
//
//   This avoids the double-ingest you get from scraping both the
//   journal *and* rsyslog's /var/log/*.log copies of the same data.
// ─────────────────────────────────────────────────────────────

// ====================  SOURCE 1: systemd journal (PRIMARY)  ====================
loki.source.journal "journal_scrape" {
  forward_to    = [loki.process.journal_labels.receiver]
  max_age       = "12h"
  relabel_rules = loki.relabel.journal.rules
  labels        = {
    job  = "systemd-journal",
    host = constants.hostname,
  }
}

// Promote useful journal fields to labels (all low-cardinality).
loki.relabel "journal" {
  forward_to = []  // exported as .rules only

  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
  rule {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "level"
  }
  rule {
    source_labels = ["__journal__transport"]
    target_label  = "transport"
  }
  rule {
    source_labels = ["__journal_syslog_identifier"]
    target_label  = "process"
  }
  // @@ALLOY_DOCKER_BEGIN@@
  // Docker's journald log-driver stamps each line with the container name and
  // image; promote them to labels so container logs are queryable, e.g.
  //   {job="systemd-journal", container="myapp"}
  rule {
    source_labels = ["__journal_container_name"]
    target_label  = "container"
  }
  rule {
    source_labels = ["__journal_image_name"]
    target_label  = "image"
  }
  // Compose project/service for grouping — populated when Docker's journald
  // `labels` log-opt includes com.docker.compose.project/service (docker.sh
  // sets this by default). Low-cardinality, so safe as labels.
  rule {
    source_labels = ["__journal_com_docker_compose_project"]
    target_label  = "compose_project"
  }
  rule {
    source_labels = ["__journal_com_docker_compose_service"]
    target_label  = "compose_service"
  }
  // Container logs already carry a `container` label, and journald sets their
  // syslog identifier to the container name — which would duplicate into
  // `process`. Clear `process` for any entry that has a container name, so that
  // label stays meaningful for real host services. (replace with "" → Loki
  // drops the empty label; non-container entries don't match, so keep theirs.)
  rule {
    source_labels = ["__journal_container_name"]
    regex         = ".+"
    target_label  = "process"
    replacement   = ""
  }
  // Loki auto-fills a `service_name` label and, left to itself, uses the
  // container name for it. Loki always assigns one (blanking it just makes it
  // re-detect), so set a single fixed service_name for container logs instead
  // of per-container names — you still group via container/compose_* labels.
  // Swap "docker" for $1 of __journal_com_docker_compose_service if you'd rather
  // service_name be the compose service.
  rule {
    source_labels = ["__journal_container_name"]
    regex         = ".+"
    target_label  = "service_name"
    replacement   = "docker"
  }
  // @@ALLOY_DOCKER_END@@
}

loki.process "journal_labels" {
  // Journal entries already carry a real timestamp and level —
  // nothing to parse, just hand off to the shared filter stage.
  forward_to = [loki.process.filter_logs.receiver]
}

// ====================  SOURCE 2: file-only logs  ====================
// Only sources that do NOT appear in the journal. Each target sets
// a meaningful `job`; loki.source.file adds a `filename` label so
// you can still tell e.g. apt history.log from term.log.
local.file_match "app_logs" {
  path_targets = [
    // Package management — what changed on the box and when.
    { __path__ = "/var/log/apt/*.log",                 job = "apt",                 host = constants.hostname },
    { __path__ = "/var/log/dpkg.log",                  job = "dpkg",                host = constants.hostname },
    { __path__ = "/var/log/unattended-upgrades/*.log", job = "unattended-upgrades", host = constants.hostname },

    // Security auditing (auditd). Comment out if auditd isn't installed.
    { __path__ = "/var/log/audit/audit.log",           job = "audit",               host = constants.hostname },

    // ── Extend here for app/web logs that log to their own files ──
    // { __path__ = "/var/log/nginx/*.log",   job = "nginx",   host = constants.hostname },
    // { __path__ = "/var/log/myapp/*.log",   job = "myapp",   host = constants.hostname },
  ]
  sync_period = "5s"
}

loki.source.file "app_log_scrape" {
  targets       = local.file_match.app_logs.targets
  forward_to    = [loki.process.parse_files.receiver]
  tail_from_end = true   // don't replay full history on first start (audit.log can be huge)
}

// These files use varied formats. Try the common ISO prefix
// (dpkg + many apps: "2026-06-06 12:34:56"); if a line doesn't
// match (apt history blocks, auditd epoch lines) we skip and fall
// back to ingest time rather than corrupting the timestamp.
loki.process "parse_files" {
  stage.regex {
    expression = "^(?P<ts>\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2})"
  }
  stage.timestamp {
    source            = "ts"
    format            = "2006-01-02 15:04:05"
    action_on_failure = "skip"
  }

  forward_to = [loki.process.filter_logs.receiver]
}

// ====================  SHARED: filtering + static labels  ====================
loki.process "filter_logs" {
  // Stamp every stream with environment metadata.
  stage.static_labels {
    values = {
      os  = "debian13",
      env = "homelab",
    }
  }

  // NOTE: the original config dropped SSH "Connection closed by
  // authenticating user root" lines. That throws away your only
  // signal of brute-force / credential-stuffing against SSH, so it
  // is intentionally DISABLED here. Re-enable only if the volume is
  // genuinely overwhelming — you lose security visibility.
  //
  // stage.drop {
  //   expression          = ".*Connection closed by authenticating user root"
  //   drop_counter_reason = "noisy"
  // }

  // Drop empty lines.
  stage.drop {
    expression          = "^\\s*$"
    drop_counter_reason = "empty"
  }

  forward_to = [loki.write.grafana_loki.receiver]
}

// ====================  OUTPUT: push to Loki  ====================
loki.write "grafana_loki" {
  endpoint {
    url = "@@LOKI_ENDPOINT@@/loki/api/v1/push"

    // Batch tuning — flush when either limit is hit.
    batch_wait = "1s"
    batch_size = "1MiB"

    // basic_auth {
    //   username = "admin"
    //   password = "admin"
    // }
  }

  // Buffer to disk so logs survive an Alloy restart or a Loki outage.
  wal {
    enabled = true
  }
}
